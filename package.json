{
  "name": "todolist",
  "version": "0.1.0",
  "private": true,
  "description": "Step-by-step React todo list harness.",
  "scripts": {
    "dev:client": "vite --host 127.0.0.1 --port 3000",
    "dev:server": "node server/index.js",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "build": "vite build",
    "start": "NODE_ENV=production node server/index.js",
    "migrate": "node server/migrate.js",
    "preview": "vite preview --host 127.0.0.1 --port 3000",
    "test": "vitest"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^6.0.2",
    "bcryptjs": "^3.0.3",
    "concurrently": "^9.2.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^1.16.0",
    "pg": "^8.21.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "supertest": "^7.2.2",
    "vite": "^8.0.14"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "jsdom": "^29.1.1",
    "vitest": "^4.1.7"
  }
}
