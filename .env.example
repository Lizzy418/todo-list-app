PORT=4000
CLIENT_ORIGIN=http://127.0.0.1:3000,http://127.0.0.1:3001
JWT_SECRET=replace-this-dev-secret
JWT_EXPIRES_IN=7d

# Production: PostgreSQL connection string from Render/Railway/etc.
DATABASE_URL=postgres://user:password@host:5432/database
PGSSLMODE=require

# Local development fallback when DATABASE_URL is not set.
DATABASE_FILE=server/data/todolist.sqlite
